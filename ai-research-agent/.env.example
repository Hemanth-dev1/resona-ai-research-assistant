# Required: OpenAI API key (get one at https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional but recommended: Serper API key for web search
# Get a free key at https://serper.dev (2500 free searches/month)
SERPER_API_KEY=your-serper-api-key-here

# Optional: Override the OpenAI model
# OPENAI_MODEL_NAME=gpt-4o

# Optional: Set to "true" for verbose agent logging
# VERBOSE=true
